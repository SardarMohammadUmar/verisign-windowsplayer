{
  "name": "artLed-player",
  "version": "1.0.0",
  "description": "Windows Digital Signage Player for ART-LED",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron.tsconfig.json",
    "dev:electron": "npm run build:electron && cross-env NODE_ENV=development electron .",
    "dist": "npm run build:renderer && npm run build:electron && electron-builder",
    "start": "electron ."
  },
  "keywords": [
    "electron",
    "digital-signage",
    "player"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "dependencies": {
    "auto-launch": "^5.0.5",
    "firebase": "^10.7.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.artled.player",
    "productName": "artLed-player",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/artled-fevicon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ]
  }
}
